#!/bin/bash
DOTFILES="${DOTFILES:-$HOME/dev/dotfiles}"

# Find fastfetch on any OS (macOS Homebrew, Linux, etc.)
FASTFETCH=""
for p in /opt/homebrew/bin/fastfetch /usr/local/bin/fastfetch /usr/bin/fastfetch; do
  [ -x "$p" ] && FASTFETCH="$p" && break
done

cf=$(find "$DOTFILES/assets/cats" -type f -name "*.png" 2>/dev/null | sort -R | head -1)
[ -z "$cf" ] && cf="$DOTFILES/assets/cats/cat2.png"
[ -f "$cf" ] && [ -n "$FASTFETCH" ] && "$FASTFETCH" --config "$DOTFILES/fastfetch/config.jsonc" --logo "$cf"
exec "$SHELL" --login
